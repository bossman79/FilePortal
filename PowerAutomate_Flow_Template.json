{
  "name": "Adept Portal - Get Files",
  "description": "Retrieves files and folders from Adept Portal project",
  "trigger": {
    "type": "manual",
    "kind": "PowerApp",
    "inputs": {
      "schema": {
        "type": "object",
        "properties": {
          "BaseURL": {
            "type": "string",
            "description": "Portal base URL (e.g. http://192.168.1.100:5000)"
          },
          "LinkUUID": {
            "type": "string",
            "description": "Share link UUID"
          },
          "Path": {
            "type": "string",
            "description": "Current folder path (leave empty for root)"
          }
        },
        "required": ["BaseURL", "LinkUUID"]
      }
    }
  },
  "actions": [
    {
      "type": "Http",
      "name": "GetExploreData",
      "inputs": {
        "method": "GET",
        "uri": "@{triggerBody()?['BaseURL']}/s/@{triggerBody()?['LinkUUID']}/api/explore?path=@{coalesce(triggerBody()?['Path'], '')}"
      }
    },
    {
      "type": "Response",
      "name": "RespondToPowerApp",
      "inputs": {
        "statusCode": 200,
        "body": "@body('GetExploreData')"
      },
      "runAfter": {
        "GetExploreData": ["Succeeded"]
      }
    }
  ]
}
